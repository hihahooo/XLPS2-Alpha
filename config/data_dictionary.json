{
  "schema_version": "1.0.0",
  "source_of_truth": "XLPS2-Alpha SSOT / LTM v3（基础18 + ADR-001扩展15 = 33字段）",
  "note": "统一数据字典为跨模块唯一事实源。OTA 传输专有字段（seq/CRC/验签状态/pending/active_slot/health_deadline/健康回执）按 ADR-006 不进入本字典，仅作 MQTT 载荷内部字段或存 FLAG 扇区。",
  "fields": [
    { "name": "current_state", "type": "uint16", "unit": "", "source": "CFW", "topic": "telemetry", "desc": "当前状态编码，按 ADR-003 层级编码 (region<<14)|(top_state<<8)|sub_state；0xFFFF=未初始化", "adr": "ADR-003" },
    { "name": "position_mm", "type": "int32", "unit": "mm", "source": "CFW", "topic": "telemetry", "desc": "相对真0点距离；真0点=靠近放入点的轨道物理端头" },
    { "name": "speed_mm_s", "type": "int16", "unit": "mm/s", "source": "CFW", "topic": "telemetry", "desc": "当前速度" },
    { "name": "battery_soc", "type": "uint8", "unit": "%", "source": "CFW", "topic": "telemetry", "desc": "电池荷电状态 0-100" },
    { "name": "track_id", "type": "uint32", "unit": "", "source": "CFW", "topic": "telemetry", "desc": "轨道ID；0=无码匿名轨道" },
    { "name": "task_status", "type": "enum", "unit": "", "source": "CFW", "topic": "telemetry", "desc": "任务状态；规范禁止 task_state 别名", "adr": "ADR-001" },
    { "name": "task_progress_pct", "type": "uint8", "unit": "%", "source": "CFW", "topic": "telemetry", "desc": "任务进度 0-100" },
    { "name": "fault_code", "type": "uint16", "unit": "", "source": "CFW", "topic": "telemetry", "desc": "故障码" },
    { "name": "fault_level", "type": "uint8", "unit": "", "source": "CFW", "topic": "telemetry", "desc": "故障级别 1-4（四级容错，ADR-006）", "adr": "ADR-006" },
    { "name": "motor_current_a", "type": "float", "unit": "A", "source": "CFW", "topic": "telemetry", "desc": "电机电流" },
    { "name": "motor_temp_c", "type": "int8", "unit": "°C", "source": "CFW", "topic": "telemetry", "desc": "电机温度" },
    { "name": "encoder_position", "type": "int32", "unit": "cnt", "source": "CFW", "topic": "telemetry", "desc": "编码器位置" },
    { "name": "laser_status", "type": "enum", "unit": "", "source": "CFW", "topic": "telemetry", "desc": "激光状态（ok/triggered/error）" },
    { "name": "photoelectric_state", "type": "enum", "unit": "", "source": "CFW", "topic": "telemetry", "desc": "光电开关量状态" },
    { "name": "ota_active_slot", "type": "enum", "unit": "", "source": "OTA", "topic": "ota/progress", "desc": "当前激活分区 A/B", "adr": "ADR-001" },
    { "name": "ota_state", "type": "enum", "unit": "", "source": "OTA", "topic": "ota/progress", "desc": "OTA状态 idle/downloading/flashing/verifying/active/rollback" },
    { "name": "ota_progress_pct", "type": "uint8", "unit": "%", "source": "OTA", "topic": "ota/progress", "desc": "OTA进度 0-100" },
    { "name": "ota_target_version", "type": "string", "unit": "", "source": "OTA", "topic": "ota/progress", "desc": "目标版本（须严格大于当前，版本单调）" },
    { "name": "ota_result", "type": "enum", "unit": "", "source": "OTA", "topic": "ota/result", "desc": "OTA结果 ok/fail/rollback" },
    { "name": "fw_version", "type": "string", "unit": "", "source": "CFW", "topic": "telemetry", "desc": "固件版本" },
    { "name": "smdl_version", "type": "string", "unit": "", "source": "CFW", "topic": "config/smdl", "desc": "运动描述语言版本" },
    { "name": "param_revision", "type": "uint32", "unit": "", "source": "CFW", "topic": "config/smdl", "desc": "参数修订号（每次热调自增）", "adr": "ADR-007" },
    { "name": "smdl_revision", "type": "uint32", "unit": "", "source": "CFW", "topic": "config/smdl", "desc": "SMDL修订号", "adr": "ADR-001" },
    { "name": "interference_count", "type": "uint16", "unit": "", "source": "CFW", "topic": "interference/sync", "desc": "干扰点命中计数（OTA私有5字段隔离之一）" },
    { "name": "diag_code", "type": "uint16", "unit": "", "source": "CFW", "topic": "diag/log", "desc": "诊断码（ADR-002 diag/log）" },
    { "name": "audit_seq", "type": "uint32", "unit": "", "source": "HMI", "topic": "audit/log", "desc": "操作审计序号（ADR-002 audit/log）" },
    { "name": "top_state", "type": "enum", "unit": "", "source": "CFW", "topic": "telemetry", "desc": "顶层状态（current_state 解码用）", "adr": "ADR-003" },
    { "name": "sub_state", "type": "enum", "unit": "", "source": "CFW", "topic": "telemetry", "desc": "子状态（current_state 解码用）", "adr": "ADR-003" },
    { "name": "region", "type": "uint8", "unit": "", "source": "CFW", "topic": "telemetry", "desc": "正交区域 0=主业务/1=能源/2=安全", "adr": "ADR-003" },
    { "name": "is_safe", "type": "bool", "unit": "", "source": "CFW", "topic": "telemetry", "desc": "安全回路状态（急停/触边）" },
    { "name": "command_in", "type": "enum", "unit": "", "source": "HMI", "topic": "telemetry", "desc": "最近入站指令" },
    { "name": "heartbeat_ts", "type": "uint32", "unit": "s", "source": "CFW", "topic": "telemetry", "desc": "心跳时间戳（epoch秒）" },
    { "name": "uptime_s", "type": "uint32", "unit": "s", "source": "CFW", "topic": "telemetry", "desc": "上电运行时间" }
  ]
}
