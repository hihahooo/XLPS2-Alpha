{
  "schema_version": "1.0.0",
  "source_of_truth": "XLPS2-Alpha SSOT / ADR-002（8基础 + 2扩展 = 10主题）",
  "topic_pattern": "rgv/{devId}/{topic}",
  "note": "devId 由 MQTT 路径承载，不进入 payload。方向 cloud=云端/operator，device=控制器，hmi=安卓App。",
  "topics": [
    { "topic": "ota/cmd", "direction": "cloud→device", "qos": 1, "payload": "OTA指令（开始/暂停/确认/回滚）；含 target_version、slot" },
    { "topic": "ota/data", "direction": "cloud→device", "qos": 1, "payload": "固件/SMDL/参数分块；含 seq、CRC、chunk（断点续传）" },
    { "topic": "ota/progress", "direction": "device→cloud", "qos": 1, "payload": "进度上报（ota_state/ota_progress_pct/ota_active_slot/ota_target_version）" },
    { "topic": "ota/result", "direction": "device→cloud", "qos": 1, "payload": "结果（ota_result=ok/fail/rollback）" },
    { "topic": "param/set", "direction": "cloud→device", "qos": 1, "payload": "参数热调（param_revision 自增，ADR-007）" },
    { "topic": "telemetry", "direction": "device→cloud", "qos": 1, "payload": "统一遥测，33字段（config/data_dictionary.json）" },
    { "topic": "config/smdl", "direction": "cloud→device", "qos": 1, "payload": "运动描述语言 SMDL 下发（smdl_version/smdl_revision）" },
    { "topic": "interference/sync", "direction": "device↔hmi/cloud", "qos": 1, "payload": "干扰点库同步；Envelope={track_id,points:[{position_mm,confirmed,hit_count}]}" },
    { "topic": "audit/log", "direction": "hmi→cloud", "qos": 1, "payload": "操作审计（audit_seq 自增，ADR-002）" },
    { "topic": "diag/log", "direction": "device→cloud", "qos": 1, "payload": "诊断/事件日志（diag_code，ADR-002）" }
  ]
}
